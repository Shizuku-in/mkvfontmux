<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MkvFontMux.Gui.Views.SettingsWindow"
        Width="774"
        Height="648"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        CanResize="False"
        SystemDecorations="BorderOnly"
        TransparencyLevelHint="AcrylicBlur"
        Title="Settings">
  <Grid>
    <Border Classes="PageBackground" />
    <Canvas IsHitTestVisible="False">
      <Ellipse Width="260" Height="260" Canvas.Left="-55" Canvas.Top="35" Fill="#66F2B880" />
      <Ellipse Width="220" Height="220" Canvas.Right="5" Canvas.Top="-12" Fill="#55F6D6A6" />
      <Ellipse Width="320" Height="320" Canvas.Left="540" Canvas.Top="340" Fill="#44D8E9FF" />
    </Canvas>

    <Border x:Name="ShellRoot"
            Classes="DialogShell SettingsTransparentShell SettingsFlatBorder"
            Padding="26"
            Margin="18"
            Opacity="0"
            RenderTransform="translateY(14px) scale(0.99)">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.24" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.34" />
        </Transitions>
      </Border.Transitions>
      <Grid RowDefinitions="Auto,*,Auto">
      <Grid ColumnDefinitions="*,Auto">
        <Border Grid.Column="0"
                Background="Transparent"
                Padding="4,4,4,18"
                PointerPressed="OnTitleBarPointerPressed">
          <StackPanel Spacing="6">
            <TextBlock Text="Settings" Classes="DialogTitle" />
            <TextBlock x:Name="IntroText" Classes="BodyMuted" />
          </StackPanel>
        </Border>
        <Button x:Name="CloseButton"
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Width="42"
                Height="42"
                Classes="WindowButton SettingsCloseButton"
                Click="OnCancelClick">
          <Path Width="16"
                Height="16"
                Stroke="#FF5A4A42"
                StrokeThickness="1.8"
                Data="M3,3 L13,13 M13,3 L3,13" />
        </Button>
      </Grid>

      <ScrollViewer Grid.Row="1"
                    Margin="0,24,0,0"
                    HorizontalScrollBarVisibility="Disabled"
                    IsScrollInertiaEnabled="True"
                    IsDeferredScrollingEnabled="False"
                    Padding="0,0,14,0">
        <StackPanel Spacing="18" Margin="0,0,8,0">
          <StackPanel Spacing="12">
            <TextBlock Text="Tool paths" Classes="SectionTitle" />
            <TextBlock Classes="BodyMuted" Text="Blank means use PATH detection." />

            <Grid ColumnDefinitions="170,*,Auto" RowDefinitions="Auto,Auto">
              <TextBlock Classes="FieldLabel" VerticalAlignment="Center" Text="mkvmerge" />
              <TextBox Grid.Column="1" x:Name="MkvmergePathTextBox" Classes="SettingsFlatInput" Watermark="Use mkvmerge from PATH" />
              <Button Grid.Column="2" Margin="10,0,0,0" MinWidth="96" Classes="SecondaryButton SettingsFlatButton" Click="OnPickMkvmergeClick">Browse</Button>

              <TextBlock Grid.Row="1" Margin="0,12,0,0" Classes="FieldLabel" VerticalAlignment="Center" Text="pyftsubset" />
              <TextBox Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" x:Name="PyftsubsetPathTextBox" Classes="SettingsFlatInput" Watermark="Use pyftsubset from PATH" />
              <Button Grid.Row="1" Grid.Column="2" Margin="10,12,0,0" MinWidth="96" Classes="SecondaryButton SettingsFlatButton" Click="OnPickPyftsubsetClick">Browse</Button>
            </Grid>
          </StackPanel>

          <Border Height="1" Background="#55FFFFFF" Margin="0,2,0,2" />

          <StackPanel Spacing="12">
            <TextBlock Text="Font folders" Classes="SectionTitle" />
            <TextBlock Classes="BodyMuted" Text="You can add multiple folders. Leave the list empty to use system fonts." />

            <ListBox x:Name="FontDirectoriesListBox" Classes="SettingsFlatInput" MinHeight="150" MaxHeight="220" SelectionMode="Multiple" />

            <Grid ColumnDefinitions="Auto,Auto,*">
              <Button Classes="SecondaryButton SettingsFlatButton" Click="OnAddFontFolderClick">Add folder</Button>
              <Button Grid.Column="1" Margin="10,0,0,0" Classes="GhostButton SettingsFlatButton" Click="OnRemoveFontFolderClick">Remove selected</Button>
            </Grid>

            <TextBlock x:Name="DefaultFontsTextBlock" Classes="BodyMuted" TextWrapping="Wrap" />
          </StackPanel>

          <Border Height="1" Background="#55FFFFFF" Margin="0,2,0,2" />

          <StackPanel Spacing="14">
            <TextBlock Text="Processing options" Classes="SectionTitle" />

            <CheckBox x:Name="UseSmartMatchCheckBox" Content="Enable smart font matching" />
            <CheckBox x:Name="EnableSubsetCheckBox" Content="Subset fonts before muxing" />
            <CheckBox x:Name="RemoveTempCheckBox" Content="Delete temporary files after processing" />
            <CheckBox x:Name="SaveSidecarLogCheckBox" Content="Also save mux.log inside the dropped folder" />
            <CheckBox x:Name="OverwriteSourceCheckBox" Content="Overwrite original MKV instead of creating output folder" />

            <StackPanel Spacing="8" Margin="0,10,0,0">
              <TextBlock Classes="FieldLabel" Text="Fallback subtitle language" />
              <ComboBox x:Name="SubtitleLanguageComboBox" Classes="SettingsFlatInput" SelectedIndex="0">
                <ComboBoxItem Content="chi - Simplified Chinese" Tag="chi" />
                <ComboBoxItem Content="cht - Traditional Chinese" Tag="cht" />
                <ComboBoxItem Content="eng - English" Tag="eng" />
                <ComboBoxItem Content="jpn - Japanese" Tag="jpn" />
              </ComboBox>
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,22,0,0">
        <TextBlock x:Name="ValidationText" VerticalAlignment="Center" Classes="ValidationText" />
        <Button Grid.Column="1" x:Name="CancelButton" Margin="10,0,0,0" Classes="GhostButton SettingsFlatButton" Click="OnCancelClick">Cancel</Button>
        <Button Grid.Column="2" Margin="10,0,0,0" Classes="ActionButton SettingsFlatButton" Click="OnSaveClick">Save</Button>
      </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>

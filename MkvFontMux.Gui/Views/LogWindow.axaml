<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MkvFontMux.Gui.Views.LogWindow"
        Width="774"
        Height="558"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        CanResize="False"
        SystemDecorations="BorderOnly"
        TransparencyLevelHint="AcrylicBlur"
        Title="Processing log">
  <Grid>
    <Border Classes="PageBackground" />
    <Canvas IsHitTestVisible="False">
      <Ellipse Width="260" Height="260" Canvas.Left="-55" Canvas.Top="35" Fill="#66F2B880" />
      <Ellipse Width="220" Height="220" Canvas.Right="5" Canvas.Top="-12" Fill="#55F6D6A6" />
      <Ellipse Width="320" Height="320" Canvas.Left="540" Canvas.Top="300" Fill="#44D8E9FF" />
    </Canvas>

    <Border x:Name="ShellRoot"
            Classes="DialogShell SettingsTransparentShell SettingsFlatBorder"
            Padding="26"
            Margin="18"
            Opacity="0"
            RenderTransform="translateY(14px) scale(0.99)">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.24" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.34" />
        </Transitions>
      </Border.Transitions>
      <Grid RowDefinitions="Auto,*,Auto">
        <Grid ColumnDefinitions="*,Auto">
          <Border Grid.Column="0"
                  Background="Transparent"
                  Padding="4"
                  PointerPressed="OnTitleBarPointerPressed">
            <StackPanel Spacing="6">
              <TextBlock Text="Processing log" Classes="DialogTitle" />
              <TextBlock x:Name="SummaryText" Classes="BodyMuted" />
            </StackPanel>
          </Border>
            <Button Grid.Column="1"
              HorizontalAlignment="Right"
              VerticalAlignment="Top"
              Width="42"
              Height="42"
              Classes="WindowButton SettingsCloseButton"
              Click="OnCloseClick">
            <Path Width="16"
                  Height="16"
                  Stroke="#FF5A4A42"
                  StrokeThickness="1.8"
                  Data="M3,3 L13,13 M13,3 L3,13" />
          </Button>
        </Grid>

        <TextBox Grid.Row="1"
                 Margin="0,24,0,12"
                 Classes="LogBox SettingsFlatInput"
                 MinHeight="260"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 VerticalContentAlignment="Top"
                 Text="{Binding LogText}" />

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,28,0,0">
          <TextBlock x:Name="FolderText" VerticalAlignment="Center" Classes="BodyMuted" />
          <Button Grid.Column="1" Margin="10,0,0,0" Classes="GhostButton SettingsFlatButton" Click="OnCloseClick">Close</Button>
          <Button Grid.Column="2" Margin="10,0,0,0" Classes="ActionButton SettingsFlatButton" Click="OnSaveLogClick">Save log</Button>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>

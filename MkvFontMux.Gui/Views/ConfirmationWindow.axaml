<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MkvFontMux.Gui.Views.ConfirmationWindow"
        Width="648"
        Height="504"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        CanResize="False"
        SystemDecorations="BorderOnly"
        TransparencyLevelHint="AcrylicBlur"
        Title="Confirm">
  <Grid>
    <Border Classes="PageBackground" />
    <Canvas IsHitTestVisible="False">
      <Ellipse Width="220" Height="220" Canvas.Left="-40" Canvas.Top="24" Fill="#66F2B880" />
      <Ellipse Width="180" Height="180" Canvas.Right="10" Canvas.Top="-10" Fill="#55F6D6A6" />
      <Ellipse Width="260" Height="260" Canvas.Left="430" Canvas.Top="270" Fill="#44D8E9FF" />
    </Canvas>

    <Border x:Name="ShellRoot"
            Classes="DialogShell SettingsTransparentShell SettingsFlatBorder"
            Padding="26"
            Margin="18"
            Opacity="0"
            RenderTransform="translateY(14px) scale(0.99)">
      <Border.Transitions>
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.24" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.34" />
        </Transitions>
      </Border.Transitions>
      <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                Background="Transparent"
                Padding="4,4,4,18"
                PointerPressed="OnTitleBarPointerPressed">
          <StackPanel Spacing="6">
            <TextBlock x:Name="TitleText" Classes="DialogTitle" />
            <TextBlock x:Name="BodyText" TextWrapping="Wrap" Classes="BodyMuted" />
          </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="0,20,0,0"
                Classes="SettingsCard SettingsTransparentCard SettingsFlatBorder"
                BorderBrush="Transparent"
                BorderThickness="0">
          <Grid RowDefinitions="Auto,*">
            <TextBlock x:Name="FolderText" Classes="FieldLabel" />
            <ListBox Grid.Row="1" Margin="0,12,0,0" x:Name="MissingFontsListBox" MinHeight="220" Classes="SettingsFlatInput">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <SelectableTextBlock Text="{Binding .}"
                                       TextWrapping="Wrap"
                                       SelectionBrush="#66D79C72"
                                       SelectionForegroundBrush="#FF2F221A" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" Margin="0,22,0,0">
          <TextBlock x:Name="FootnoteText" VerticalAlignment="Center" Classes="BodyMuted" />
          <Button Grid.Column="1" Margin="10,0,0,0" Classes="GhostButton SettingsFlatButton" Click="OnBackClick">Back</Button>
          <Button Grid.Column="2" Margin="10,0,0,0" Classes="ActionButton SettingsFlatButton" Click="OnContinueClick">Continue</Button>
        </Grid>
      </Grid>
    </Border>
  </Grid>
</Window>

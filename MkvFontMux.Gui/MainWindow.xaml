<Window x:Class="MkvFontMux.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MkvFontMux GUI" Height="740" Width="980" MinHeight="680" MinWidth="920">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="220"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="90"/>
        </Grid.ColumnDefinitions>

        <Menu Grid.Row="0" Grid.ColumnSpan="3" Margin="-16,-16,-16,0">
            <MenuItem x:Name="LanguageMenuItem" Header="Language">
                <MenuItem x:Name="LanguageZhMenuItem" Header="简体中文" IsCheckable="True" Click="LanguageZhMenuItem_Click"/>
                <MenuItem x:Name="LanguageEnMenuItem" Header="English" IsCheckable="True" Click="LanguageEnMenuItem_Click"/>
                <MenuItem x:Name="LanguageZhHantMenuItem" Header="繁體中文" IsCheckable="True" Click="LanguageZhHantMenuItem_Click"/>
            </MenuItem>
            <MenuItem x:Name="AboutMenuItem" Header="About" Click="AboutMenuItem_Click"/>
        </Menu>

        <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,8,0,10">
            <TextBlock x:Name="TitleTextBlock" Text="MkvFontMux GUI (MVP)" FontSize="22" FontWeight="SemiBold"/>
        </StackPanel>

        <TextBlock x:Name="WorkDirLabel" Grid.Row="2" Grid.Column="0" Text="工作目录" VerticalAlignment="Center"/>
        <TextBox x:Name="WorkDirTextBox" Grid.Row="2" Grid.Column="1" Margin="6,4"
                 AllowDrop="True"
                 PreviewDragEnter="PathTextBox_PreviewDragEnter"
                 PreviewDragOver="PathTextBox_PreviewDragOver"
                 PreviewDragLeave="PathTextBox_PreviewDragLeave"
                 Drop="WorkDirTextBox_Drop"/>
        <Button x:Name="BrowseWorkDirButton" Grid.Row="2" Grid.Column="2" Margin="6,4" Content="浏览" Click="BrowseWorkDir_Click"/>

        <TextBlock x:Name="FontDirsLabel" Grid.Row="3" Grid.Column="0" Text="字体目录(;分隔)" VerticalAlignment="Center"/>
        <TextBox x:Name="FontDirsTextBox" Grid.Row="3" Grid.Column="1" Margin="6,4"
                 AllowDrop="True"
                 PreviewDragEnter="PathTextBox_PreviewDragEnter"
                 PreviewDragOver="PathTextBox_PreviewDragOver"
                 PreviewDragLeave="PathTextBox_PreviewDragLeave"
                 Drop="FontDirsTextBox_Drop"/>
        <Button x:Name="BrowseFontDirButton" Grid.Row="3" Grid.Column="2" Margin="6,4" Content="浏览" Click="BrowseFontDir_Click"/>

        <TextBlock x:Name="MkvmergeLabel" Grid.Row="4" Grid.Column="0" Text="mkvmerge 路径(可选)" VerticalAlignment="Center"/>
        <TextBox x:Name="MkvmergeTextBox" Grid.Row="4" Grid.Column="1" Margin="6,4"
                 AllowDrop="True"
                 PreviewDragEnter="PathTextBox_PreviewDragEnter"
                 PreviewDragOver="PathTextBox_PreviewDragOver"
                 PreviewDragLeave="PathTextBox_PreviewDragLeave"
                 Drop="MkvmergeTextBox_Drop"/>
        <Button x:Name="BrowseMkvmergeButton" Grid.Row="4" Grid.Column="2" Margin="6,4" Content="浏览" Click="BrowseMkvmerge_Click"/>

        <TextBlock x:Name="PyftsubsetLabel" Grid.Row="5" Grid.Column="0" Text="pyftsubset 路径(可选)" VerticalAlignment="Center"/>
        <TextBox x:Name="PyftsubsetTextBox" Grid.Row="5" Grid.Column="1" Margin="6,4"
                 AllowDrop="True"
                 PreviewDragEnter="PathTextBox_PreviewDragEnter"
                 PreviewDragOver="PathTextBox_PreviewDragOver"
                 PreviewDragLeave="PathTextBox_PreviewDragLeave"
                 Drop="PyftsubsetTextBox_Drop"/>
        <Button x:Name="BrowsePyftsubsetButton" Grid.Row="5" Grid.Column="2" Margin="6,4" Content="浏览" Click="BrowsePyftsubset_Click"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,8,0,8">
            <CheckBox x:Name="ForceMatchCheckBox" Content="强制精确匹配" Margin="0,0,18,0"/>
            <CheckBox x:Name="DisableSubsetCheckBox" Content="禁用子集化" Margin="0,0,18,0"/>
            <CheckBox x:Name="SaveLogCheckBox" Content="保存日志" Margin="0,0,18,0"/>
            <CheckBox x:Name="OverwriteCheckBox" Content="覆盖源MKV" Margin="0,0,18,0"/>
            <CheckBox x:Name="RemoveTempCheckBox" Content="完成后删除临时文件" IsChecked="True" Margin="0,0,18,0"/>
            <CheckBox x:Name="OnlyMatchCheckBox" Content="仅字体匹配报告"/>
        </StackPanel>

        <StackPanel Grid.Row="7" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock x:Name="SubtitleLanguageLabel" Text="字幕语言代码" VerticalAlignment="Center"/>
            <TextBox x:Name="SubtitleLangTextBox" Text="chi" Width="90" Margin="10,0,18,0"/>
            <Button x:Name="StartButton" Content="开始" Width="120" Height="32" Click="StartButton_Click" Margin="0,0,8,0"/>
            <Button x:Name="CancelButton" Content="取消" Width="120" Height="32" Click="CancelButton_Click" IsEnabled="False"/>
            <Button x:Name="ExportLogButton" Content="导出日志" Width="120" Height="32" Click="ExportLogButton_Click" Margin="8,0,0,0"/>
            <Button x:Name="ExportMissingFontsButton" Content="导出缺失字体CSV" Width="140" Height="32" Click="ExportMissingFontsButton_Click" Margin="8,0,0,0"/>
        </StackPanel>

        <DataGrid x:Name="FileReportGrid" Grid.Row="8" Grid.ColumnSpan="3" Margin="0,8,0,8"
                  AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="MKV" Binding="{Binding FileName}" Width="2*"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="120"/>
                <DataGridTextColumn Header="缺失字体数" Binding="{Binding MissingCount}" Width="120"/>
                <DataGridTextColumn Header="缺失字体" Binding="{Binding MissingFonts}" Width="3*"/>
                <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="3*"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBox x:Name="LogTextBox" Grid.Row="9" Grid.ColumnSpan="3" Margin="0,8,0,8"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" AcceptsReturn="True" AcceptsTab="True" IsReadOnly="True"/>

        <StackPanel Grid.Row="10" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center">
            <ProgressBar x:Name="RunProgressBar" Width="320" Height="18" IsIndeterminate="False"/>
            <TextBlock x:Name="StatusTextBlock" Text="就绪" Margin="12,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Window>
